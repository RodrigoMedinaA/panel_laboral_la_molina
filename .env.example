APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# — Obligatorias ————————————————————————————————————————

# URL base del SSO — sin barra al final
SSO_URL=

# Slug que identifica a ESTA aplicación dentro del SSO.
# Debe coincidir exactamente con el slug registrado en el backoffice del IAM.
# Este valor se usa para filtrar el array "systems" que viene en el JWT.
SYSTEM_SLUG=

# — Opcionales (el paquete usa estos defaults si no se definen) —

# Segundos que se cachean las llaves públicas JWKS. Default: 86400 (24 horas).
# Reducir solo durante desarrollo activo o rotación de llaves.
SSO_JWKS_TTL=

# Ruta relativa al endpoint JWKS dentro del SSO.
# Default: /.well-known/jwks.json (estándar RFC 8615)
SSO_JWKS_PATH=

# Margen de tolerancia en segundos para diferencias de reloj entre servidores.
# Default: 60. No superar 120 en producción.
SSO_JWT_LEEWAY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
